# Database (PostgreSQL via Supabase or any Postgres provider)
DATABASE_URL=
DIRECT_URL=

# JWT Secret — use a long random string in production (at least 32 characters)
JWT_SECRET=change-this-to-a-long-random-secret-string

# Resend API Key — get one at https://resend.com (free tier works)
RESEND_API_KEY=

# Base URL for email links (e.g. http://localhost:3000 locally)
NEXT_PUBLIC_BASE_URL=http://localhost:3000